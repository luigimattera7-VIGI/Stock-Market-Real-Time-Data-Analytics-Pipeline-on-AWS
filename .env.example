# Environment Variables Example
# Copy this file to .env and fill in your actual values
# NOTE: Never commit the .env file to version control

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Kinesis Configuration
KINESIS_STREAM_NAME=stock-market-stream
STOCK_SYMBOL=USDCLP=X
DELAY_TIME=30

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=stock-market-data

# S3 Configuration
S3_BUCKET_NAME=stock-market-data-bucket-xxxxx
S3_RAW_DATA_PREFIX=raw-data
S3_PROCESSED_DATA_PREFIX=processed-data

# Lambda Configuration
LAMBDA_TIMEOUT=60
LAMBDA_MEMORY=256

# SNS Configuration
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:xxxxx:stock-alerts
ALERT_THRESHOLD=5

# Logging
LOG_LEVEL=INFO
ENABLE_DEBUG=false
